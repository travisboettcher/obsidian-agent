# Required secrets — set these in Gitea Actions → Settings → Secrets & Variables → Actions

# Claude API key from console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Gitea personal access token with repo write + PR create scope
# Note: Gitea reserves the GITEA_ prefix for built-in variables, so use AUTH_TOKEN
AUTH_TOKEN=your-gitea-token-here

# --- Actions Variables (Settings → Secrets & Variables → Variables, not Secrets) ---

# Gitea instance base URL (no trailing slash)
BASE_URL=https://gitea.example.com

# owner/repo of the vault repository on Gitea
VAULT_REPO=boettcherta/obsidian-vault

# --- Set automatically by the workflow, not secrets ---
# VAULT_DIR=./vault        (path to checked-out vault)
# WEEK=2026-W11            (ISO week string, e.g. 2026-W11)
# DRY_RUN=1                (set to 1 to skip write_file / append_to_file calls)
