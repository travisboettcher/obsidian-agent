# Required secrets — set these in GitHub Actions → Settings → Secrets and variables → Actions

# Claude API key from console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Set automatically by the workflow, not secrets ---
# VAULT_DIR=./vault        (path to checked-out vault)
# WEEK=2026-W11            (ISO week string, e.g. 2026-W11)   — used by agent.py
# DATE=2026-03-29          (ISO date string, e.g. 2026-03-29) — used by daily_agent.py
# DRY_RUN=1                (set to 1 to skip write_file calls)
